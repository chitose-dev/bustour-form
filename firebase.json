{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".github/**",
      "backend-admin/**",
      "backend-booking/**",
      "deploy.sh",
      "README.md"
    ],
    "rewrites": [
      {
        "source": "/admin",
        "destination": "/admin.html"
      },
      {
        "source": "/pickup",
        "destination": "/pickup.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
